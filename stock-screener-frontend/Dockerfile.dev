# Development Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source (will be overridden by volume mount)
COPY . .

EXPOSE 3000

# Run dev server with host binding for Docker (port from vite.config.ts)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
