# Stock Screener Dashboard - Environment Variables
# Copy this file to .env and modify as needed

# =============================================================================
# Backend Configuration
# =============================================================================

# Server port
PORT=8080

# Gin mode: debug or release (read by the app — affects logging verbosity)
GIN_MODE=release

# Demo mode: true = use mock data, false = use Yahoo Finance API
# Default is live mode (false); set true only when you need mock data
DEMO_MODE=false

# Yahoo quote implementation when using Yahoo-backed routes (swap without code changes):
#   resty   — direct query1.finance.yahoo.com HTTP via Resty (default; highest field parity)
#   ffeng   — github.com/FFengIll/yfinance-go
#   ampyfin — github.com/AmpyFin/yfinance-go (per-symbol; uses session rotation)
YAHOO_QUOTE_DRIVER=resty

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Cache default TTL for in-memory API cache (Go duration, e.g. 5m, 1h)
CACHE_TTL=5m

# =============================================================================
# Frontend Configuration (Vite)
# =============================================================================

# Optional: full backend origin when the browser must call the API directly
# (e.g. no /api proxy). If unset, the app uses relative /api/v1 and the Vite
# dev proxy (local) or nginx (production).
# VITE_API_URL=http://localhost:8080

# Docker Compose dev only: where the Vite dev server proxies /api (set in docker-compose.dev.yml)
# VITE_DEV_PROXY_TARGET=http://backend:8080

# =============================================================================
# Data providers (redundant live channels)
# =============================================================================
#
# Stock/screener routes use a provider manager: FMP and Alpha Vantage are tried
# before Yahoo when keys are set. For operations, keep at least two channels
# configured and healthy — see: make verify-providers
#
# Minimum successful probes (default 2): MIN_WORKING_PROVIDERS=2
MIN_WORKING_PROVIDERS=2

FMP_API_KEY=
ALPHA_VANTAGE_KEY=

# =============================================================================
# Docker Compose Overrides
# =============================================================================

# BACKEND_PORT=8080
# FRONTEND_PORT=3000
