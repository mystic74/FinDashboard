# Stock Screener Dashboard - Environment Variables
# Copy this file to .env and modify as needed

# =============================================================================
# Backend Configuration
# =============================================================================

# Server port
PORT=8080

# Gin mode: debug or release
GIN_MODE=release

# Demo mode: true = use mock data, false = use Yahoo Finance API
# Note: Yahoo Finance may block requests in some environments
DEMO_MODE=true

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Cache TTL (time-to-live) for API responses
CACHE_TTL=5m

# =============================================================================
# Frontend Configuration (Vite)
# =============================================================================

# Backend API URL
VITE_API_URL=http://localhost:8080

# =============================================================================
# Data Providers (Optional - enables live data when DEMO_MODE=false)
# =============================================================================
#
# The app supports multiple data providers with automatic fallback:
# 1. Yahoo Finance (unofficial, no key needed, may be blocked)
# 2. Financial Modeling Prep (free tier: 250 calls/day)
# 3. Alpha Vantage (free tier: 25 calls/day, 5 calls/minute)
#
# Get your free API keys:
# - FMP: https://financialmodelingprep.com/developer/docs/
# - Alpha Vantage: https://www.alphavantage.co/support/#api-key
#
# Rate Limit Handling:
# - Automatic retry with exponential backoff
# - Graceful fallback between providers
# - Falls back to mock data if all providers fail

# Financial Modeling Prep API Key (recommended - higher limits)
# Free tier: 250 requests/day
# FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage API Key
# Free tier: 25 requests/day, 5 requests/minute
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# =============================================================================
# Docker Compose Overrides
# =============================================================================

# These are used in docker-compose.yml
# Uncomment and modify if needed

# BACKEND_PORT=8080
# FRONTEND_PORT=3000
