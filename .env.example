# Stock Screener Dashboard - Environment Variables
# Copy this file to .env and modify as needed

# =============================================================================
# Backend Configuration
# =============================================================================

# Server port
PORT=8080

# Gin mode: debug or release (read by the app — affects logging verbosity)
GIN_MODE=release

# Demo mode: true = use mock data, false = use Yahoo Finance API
# Note: Yahoo Finance may block requests in some environments
DEMO_MODE=true

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Cache default TTL for in-memory API cache (Go duration, e.g. 5m, 1h)
CACHE_TTL=5m

# =============================================================================
# Frontend Configuration (Vite)
# =============================================================================

# Optional: full backend origin when the browser must call the API directly
# (e.g. no /api proxy). If unset, the app uses relative /api/v1 and the Vite
# dev proxy (local) or nginx (production).
# VITE_API_URL=http://localhost:8080

# Docker Compose dev only: where the Vite dev server proxies /api (set in docker-compose.dev.yml)
# VITE_DEV_PROXY_TARGET=http://backend:8080

# =============================================================================
# Data providers (not used by HTTP API today)
# =============================================================================
#
# Live screeners and stock endpoints use Yahoo Finance only when DEMO_MODE=false.
# FMP / Alpha Vantage helpers exist under services/ but are not wired into routes.
# Keys below are reserved for future integration.
#
# FMP_API_KEY=
# ALPHA_VANTAGE_KEY=

# =============================================================================
# Docker Compose Overrides
# =============================================================================

# BACKEND_PORT=8080
# FRONTEND_PORT=3000
